rules_version = '2';

// Files live under /orgs/{orgId}/... and mirror Firestore org isolation.
// Membership and role checks read the same organization_members docs.
service firebase.storage {
  match /b/{bucket}/o {
    function isMember(orgId) {
      return request.auth != null &&
        firestore.exists(/databases/(default)/documents/organization_members/$(orgId + '_' + request.auth.uid));
    }

    function role(orgId) {
      return firestore.get(/databases/(default)/documents/organization_members/$(orgId + '_' + request.auth.uid)).data.role;
    }

    function isStaff(orgId) {
      return isMember(orgId) && role(orgId) in ['owner', 'admin', 'tutor', 'frontdesk', 'accountant'];
    }

    // Documents are server-mediated (DEV_PLAN E3.9): the server sniffs the
    // real file signature before writing via the Admin SDK (which bypasses
    // these rules) and hands clients a short-lived signed URL for reads
    // (also outside these rules). Direct client access is denied so nobody
    // can bypass the content-type sniffing or read without going through
    // an authorization check first.
    match /orgs/{orgId}/documents/{allPaths=**} {
      allow read, write: if false;
    }

    match /orgs/{orgId}/{allPaths=**} {
      allow read: if isMember(orgId);
      // 5MB cap and safe content types enforced at the edge.
      allow write: if isStaff(orgId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/(jpeg|png)|text/plain|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }

    // Homework submissions: students write into their own submission folder.
    match /orgs/{orgId}/submissions/{studentUserId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == studentUserId
        && isMember(orgId)
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('application/pdf|image/(jpeg|png)|text/plain|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
