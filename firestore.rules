rules_version = '2';

// ClassStackr security rules.
//
// Constitution (see GO_TO_MARKET_BLUEPRINT.md section 9.3):
//  - Roles live in organization_members docs, written ONLY by the server
//    (Admin SDK bypasses rules; there is no client write path to membership).
//  - Money collections (wallets, wallet_ledger, invoices, payments,
//    transactions, billing_events, attendance_records) are NEVER
//    client-writable. Mutations go through /api/v1/billing.
//  - Parents reach child data through parent_links docs (id: parentUid_studentId),
//    students through students.studentUserId.
//  - google_tokens and audit_events writes have no client path at all.

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helpers
    // ===============================================================
    function isAuthed() {
      return request.auth != null;
    }

    function isOwnerUid(userId) {
      return isAuthed() && request.auth.uid == userId;
    }

    function memberDoc(orgId) {
      return get(/databases/$(database)/documents/organization_members/$(orgId + '_' + request.auth.uid));
    }

    function isMember(orgId) {
      return isAuthed() && orgId != null &&
        exists(/databases/$(database)/documents/organization_members/$(orgId + '_' + request.auth.uid));
    }

    function roleIn(orgId, roles) {
      return isMember(orgId) && memberDoc(orgId).data.role in roles;
    }

    function isStaff(orgId) {
      return roleIn(orgId, ['owner', 'admin', 'tutor', 'frontdesk', 'accountant']);
    }

    function isAdmin(orgId) {
      return roleIn(orgId, ['owner', 'admin']);
    }

    function isParentOf(studentId) {
      return isAuthed() &&
        exists(/databases/$(database)/documents/parent_links/$(request.auth.uid + '_' + studentId));
    }

    function isStudentSelf(studentId) {
      return isAuthed() &&
        get(/databases/$(database)/documents/students/$(studentId)).data.studentUserId == request.auth.uid;
    }

    function onlyChanges(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function orgUnchanged() {
      return request.resource.data.organizationId == resource.data.organizationId;
    }

    // ===============================================================
    // Identity
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwnerUid(userId) || isAdmin(resource.data.organizationId);
      allow create: if isOwnerUid(userId)
        // Authorization-bearing fields can never be self-assigned. role_type
        // is a display-only onboarding preference; rules and the API never
        // consult it.
        && !request.resource.data.keys().hasAny(['role', 'organizationId', 'roles']);
      // C1 fix: profile fields only; role/org membership can never be
      // self-served through this document.
      allow update: if isOwnerUid(userId)
        && onlyChanges(['name', 'phone', 'phone_number', 'school', 'grade', 'timezone',
                        'photoUrl', 'preferences', 'role_type', 'profile_status', 'updatedAt']);
      allow delete: if false;
    }

    // C5 fix: profiles visible inside the organization only.
    match /tutor_profiles/{userId} {
      allow read: if isOwnerUid(userId) || isStaff(resource.data.organizationId);
      allow create, update: if isOwnerUid(userId);
      allow delete: if false;
    }

    match /parent_profiles/{userId} {
      allow read: if isOwnerUid(userId) || isAdmin(resource.data.organizationId);
      allow create, update: if isOwnerUid(userId);
      allow delete: if false;
    }

    match /student_profiles/{userId} {
      allow read: if isOwnerUid(userId)
        || isAdmin(resource.data.organizationId)
        || (isAuthed() && resource.data.parent_id == request.auth.uid);
      allow create: if isOwnerUid(userId)
        || (isAuthed() && request.resource.data.parent_id == request.auth.uid);
      allow update: if isOwnerUid(userId)
        || (isAuthed() && resource.data.parent_id == request.auth.uid);
      allow delete: if false;
    }

    // ===============================================================
    // Organization structure: memberships are server-written only
    // ===============================================================

    match /organizations/{orgId} {
      allow read: if isMember(orgId);
      allow update: if isAdmin(orgId);
      // Creation happens via /api/v1/members/bootstrap so the owner
      // membership + custom claims are set atomically.
      allow create, delete: if false;
    }

    match /organization_members/{memberId} {
      allow read: if isAuthed() &&
        (request.auth.uid == resource.data.userId || isStaff(resource.data.organizationId));
      // C1/C3 fix: no client path to grant or change roles.
      allow create, update, delete: if false;
    }

    match /parent_links/{linkId} {
      allow read: if isAuthed() &&
        (resource.data.parentUserId == request.auth.uid || isStaff(resource.data.organizationId));
      // Created server-side during verified parent onboarding.
      allow create, update, delete: if false;
    }

    // E10.1: single-use tokens minted by staff and redeemed by a phone-OTP
    // verified parent via /api/v1/parents. Never client-readable — the
    // preview a parent sees on the redeem screen comes from the server
    // (GET /api/v1/parents/invites/:token/preview), not a direct read.
    match /parent_invites/{token} {
      allow read, write: if false;
    }

    // ===============================================================
    // People
    // ===============================================================

    match /students/{studentId} {
      allow read: if isStaff(resource.data.organizationId)
        || resource.data.studentUserId == request.auth.uid
        || isParentOf(studentId);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk']);
      allow update: if orgUnchanged() && (
        roleIn(resource.data.organizationId, ['owner', 'admin', 'frontdesk'])
        || (roleIn(resource.data.organizationId, ['tutor']) && onlyChanges(['notes', 'updatedAt']))
      );
      // Soft-archive via update; financial history makes hard deletes illegal.
      allow delete: if false;
    }

    match /leads/{leadId} {
      allow read: if roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk']);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk']);
      allow update: if orgUnchanged() && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk']);
      allow delete: if isAdmin(resource.data.organizationId);
    }

    // ===============================================================
    // Curriculum & scheduling
    // ===============================================================

    match /programs/{programId} {
      allow read: if isStaff(resource.data.organizationId);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow update: if orgUnchanged() && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow delete: if isAdmin(resource.data.organizationId);
    }

    match /courses/{courseId} {
      allow read: if isStaff(resource.data.organizationId);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow update: if orgUnchanged() && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow delete: if isAdmin(resource.data.organizationId);
    }

    match /class_templates/{templateId} {
      allow read: if isStaff(resource.data.organizationId);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow update: if orgUnchanged() && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow delete: if isAdmin(resource.data.organizationId);
    }

    match /class_sessions/{sessionId} {
      // Students/parents read via denormalized UID arrays maintained by the
      // server-side session writer.
      allow read: if isStaff(resource.data.organizationId)
        || (resource.data.keys().hasAny(['studentUserIds']) && request.auth.uid in resource.data.studentUserIds)
        || (resource.data.keys().hasAny(['parentUserIds']) && request.auth.uid in resource.data.parentUserIds);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk']);
      // Status transitions to completed (attendance) happen server-side only.
      allow update: if orgUnchanged()
        && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk'])
        && request.resource.data.status != 'completed';
      allow delete: if isAdmin(resource.data.organizationId);
    }

    match /tutor_availability/{availabilityId} {
      allow read: if isStaff(resource.data.organizationId);
      allow create: if isStaff(request.resource.data.organizationId)
        && (request.resource.data.tutorId == request.auth.uid || isAdmin(request.resource.data.organizationId));
      allow update, delete: if isStaff(resource.data.organizationId)
        && (resource.data.tutorId == request.auth.uid || isAdmin(resource.data.organizationId));
    }

    match /enrollments/{enrollmentId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk']);
      allow update: if orgUnchanged() && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk']);
      allow delete: if false;
    }

    match /session_requests/{requestId} {
      allow read: if isStaff(resource.data.organizationId)
        || resource.data.requestedByUserId == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.requestedByUserId == request.auth.uid;
      allow update: if isStaff(resource.data.organizationId)
        || resource.data.requestedByUserId == request.auth.uid;
      allow delete: if isAdmin(resource.data.organizationId);
    }

    // ===============================================================
    // Money: C2 fix — zero client write paths
    // ===============================================================

    match /invoices/{invoiceId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      allow create, update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      allow create, update, delete: if false;
    }

    match /wallets/{walletId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      allow create, update, delete: if false;
    }

    match /wallet_ledger/{entryId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      allow create, update, delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      allow create, update, delete: if false;
    }

    match /billing_events/{eventId} {
      allow read: if isStaff(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /attendance_records/{recordId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      // Written only by /api/v1/billing/attendance inside a transaction.
      allow create, update, delete: if false;
    }

    // ===============================================================
    // Learning
    // ===============================================================

    match /assessments/{assessmentId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId);
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow update: if orgUnchanged() && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow delete: if isAdmin(resource.data.organizationId);
    }

    match /documents/{documentId} {
      allow read: if isStaff(resource.data.organizationId)
        || isParentOf(resource.data.studentId)
        || isStudentSelf(resource.data.studentId)
        || resource.data.uploadedByUserId == request.auth.uid;
      allow create: if roleIn(request.resource.data.organizationId, ['owner', 'admin', 'tutor', 'frontdesk'])
        || (isAuthed() && request.resource.data.uploadedByUserId == request.auth.uid
            && isStudentSelf(request.resource.data.studentId));
      allow update: if orgUnchanged() && roleIn(resource.data.organizationId, ['owner', 'admin', 'tutor']);
      allow delete: if isAdmin(resource.data.organizationId);
    }

    // ===============================================================
    // Communication: C4 fix — participants only
    // ===============================================================

    match /conversations/{conversationId} {
      allow read: if isAuthed() && request.auth.uid in resource.data.participantIds;
      allow create: if isMember(request.resource.data.organizationId)
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAuthed() && request.auth.uid in resource.data.participantIds
        && orgUnchanged()
        && onlyChanges(['lastMessageAt', 'lastMessagePreview', 'unreadCounts', 'updatedAt']);
      allow delete: if false;
    }

    match /messages/{messageId} {
      allow read: if isAuthed() && request.auth.uid in resource.data.participantIds;
      allow create: if isMember(request.resource.data.organizationId)
        && request.resource.data.senderUserId == request.auth.uid
        && request.auth.uid in request.resource.data.participantIds;
      allow update: if isAuthed() && resource.data.senderUserId == request.auth.uid
        && onlyChanges(['body', 'editedAt', 'readBy']);
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create: if isStaff(request.resource.data.organizationId);
    }

    // ===============================================================
    // Governance: server-written, admin-readable
    // ===============================================================

    match /audit_events/{eventId} {
      allow read: if isAdmin(resource.data.organizationId)
        || roleIn(resource.data.organizationId, ['accountant']);
      allow create, update, delete: if false;
    }

    // google_tokens, org_stats_daily, feature_flags, subscriptions:
    // intentionally no client match — default deny, server-only.
    match /org_stats_daily/{statId} {
      allow read: if isStaff(resource.data.organizationId);
      allow create, update, delete: if false;
    }

    match /feature_flags/{orgId} {
      allow read: if isMember(orgId);
      allow create, update, delete: if false;
    }
  }
}
