# APP_URL: The public URL where this app is hosted. Used for self-referential
# links, OAuth callbacks, and webhook registration. Set to your deployed origin
# in production; http://localhost:3000 for local dev.
APP_URL="http://localhost:3000"

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
# Generate with: openssl rand -hex 32
JWT_SECRET="your_jwt_secret_here"
# AES-256-GCM key for Google refresh tokens. Generate with: openssl rand -hex 32
# Production: store in Google Secret Manager, never in a file.
ENCRYPTION_KEY="your_32_byte_encryption_key_here"

# Supabase — see supabase/README.md. Option A (hosted, recommended): copy values
# from Dashboard → Project Settings → API and → Database. Option B (self-hosted):
# point these at your stack's Kong URL (e.g. http://<vm-ip>:8000).
# Hosted example URL: https://<project-ref>.supabase.co
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
# Direct Postgres connection (bypasses PostgREST) for routes that need real
# multi-statement transactions — see server/db.ts. Use the pooler URI (hosted:
# Project Settings → Database → Connection string).
DATABASE_URL="postgres://postgres:your_postgres_password@localhost:5432/postgres"
# Hosted: Project Settings → API → JWT Settings → JWT Secret. Used to verify user
# session tokens locally without an extra network round trip per request.
SUPABASE_JWT_SECRET="your_supabase_jwt_secret"

# Sentry (optional; error tracking is skipped when unset)
SENTRY_DSN="your_backend_sentry_dsn"
VITE_SENTRY_DSN="your_frontend_sentry_dsn"

# Shared secret for Cloud Scheduler-triggered endpoints (/api/cron/*).
# Generate with: openssl rand -hex 32
CRON_SECRET="your_cron_secret_here"

