# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
# Generate with: openssl rand -hex 32
JWT_SECRET="your_jwt_secret_here"
# AES-256-GCM key for Google refresh tokens. Generate with: openssl rand -hex 32
# Production: store in Google Secret Manager, never in a file.
ENCRYPTION_KEY="your_32_byte_encryption_key_here"

# Firebase Configuration
VITE_FIREBASE_API_KEY="your_firebase_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_firebase_auth_domain"
VITE_FIREBASE_PROJECT_ID="your_firebase_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_firebase_storage_bucket"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_firebase_messaging_sender_id"
VITE_FIREBASE_APP_ID="your_firebase_app_id"
VITE_FIREBASE_DATABASE_ID="your_firebase_database_id"

# Sentry (optional; error tracking is skipped when unset)
SENTRY_DSN="your_backend_sentry_dsn"
VITE_SENTRY_DSN="your_frontend_sentry_dsn"

# Shared secret for Cloud Scheduler-triggered endpoints (/api/cron/*).
# Generate with: openssl rand -hex 32
CRON_SECRET="your_cron_secret_here"

