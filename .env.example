# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
# Generate with: openssl rand -hex 32
JWT_SECRET="your_jwt_secret_here"
# AES-256-GCM key for Google refresh tokens. Generate with: openssl rand -hex 32
# Production: store in Google Secret Manager, never in a file.
ENCRYPTION_KEY="your_32_byte_encryption_key_here"

# Supabase Configuration — see supabase/README.md for self-hosting setup.
VITE_SUPABASE_URL="http://localhost:8000"
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_URL="http://localhost:8000"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"
# Direct Postgres connection (bypasses PostgREST) for routes that need real
# multi-statement transactions — see server/db.ts and supabase/README.md.
DATABASE_URL="postgres://postgres:your_postgres_password@localhost:5432/postgres"
# Same value as JWT_SECRET in supabase/docker/.env — used to verify user
# session tokens locally without an extra network round trip per request.
SUPABASE_JWT_SECRET="your_supabase_jwt_secret"

# Sentry (optional; error tracking is skipped when unset)
SENTRY_DSN="your_backend_sentry_dsn"
VITE_SENTRY_DSN="your_frontend_sentry_dsn"

# Shared secret for Cloud Scheduler-triggered endpoints (/api/cron/*).
# Generate with: openssl rand -hex 32
CRON_SECRET="your_cron_secret_here"

