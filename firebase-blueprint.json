{
  "entities": {
    "TutorProfile": {
      "title": "Tutor Profile",
      "description": "Tutor specific profile data",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "full_name": { "type": "string" },
        "profile_photo_url": { "type": "string" },
        "bio": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "grades": { "type": "array", "items": { "type": "string" } },
        "experience_years": { "type": "number" },
        "qualification": { "type": "string" },
        "teaching_mode": { "type": "string" },
        "location": { "type": "string" },
        "price_model": { "type": "string" },
        "price_range_min": { "type": "number" },
        "price_range_max": { "type": "number" },
        "max_batch_size": { "type": "number" },
        "availability_slots": { "type": "array", "items": { "type": "object" } },
        "is_verified": { "type": "boolean" }
      },
      "required": ["user_id"]
    },
    "ParentProfile": {
      "title": "Parent Profile",
      "description": "Parent specific profile data",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "full_name": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["user_id"]
    },
    "StudentProfile": {
      "title": "Student Profile",
      "description": "Student specific profile data",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "full_name": { "type": "string" },
        "parent_id": { "type": "string" },
        "grade": { "type": "string" },
        "board": { "type": "string" },
        "dob": { "type": "string" },
        "learning_preferences": { "type": "string" },
        "subjects_needed": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["user_id"]
    },
    "User": {
      "title": "User",
      "description": "Global user account",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "Organization": {
      "title": "Organization",
      "description": "Tenant / Coaching center / Tutor business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "ownerUserId": { "type": "string" },
        "timezone": { "type": "string" },
        "currency": { "type": "string" },
        "isActive": { "type": "boolean" },
        "settings": {
          "type": "object",
          "description": "Global organization settings for various modules"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerUserId"]
    },
    "OrganizationMember": {
      "title": "Organization Member",
      "description": "User's role within an organization",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["owner", "admin", "tutor", "staff"] },
        "permissions": { "type": "object" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "userId", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record scoped to organization",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "name": { "type": "string" },
        "grade": { "type": "string" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "name"]
    },
    "StudentParent": {
      "title": "Student Parent",
      "description": "Link between student and parent user",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "parentUserId": { "type": "string" },
        "relationship": { "type": "string" },
        "isPrimary": { "type": "boolean" }
      },
      "required": ["studentId", "parentUserId"]
    },
    "Program": {
      "title": "Program",
      "description": "Educational program (e.g., Grade 10 CBSE)",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "name"]
    },
    "Course": {
      "title": "Course",
      "description": "Course within a program (e.g., Mathematics)",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "programId": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "programId", "name"]
    },
    "ClassTemplate": {
      "title": "Class Template",
      "description": "Definition of a class offering and recurring rules",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "courseId": { "type": "string" },
        "tutorId": { "type": "string" },
        "type": { "type": "string", "enum": ["BATCH", "ONE_ON_ONE", "CRASH_COURSE", "WORKSHOP"] },
        "pricingModel": { "type": "string", "enum": ["MONTHLY", "PER_SESSION", "PACKAGE", "FLAT_FEE"] },
        "feeAmount": { "type": "number" },
        "capacity": { "type": "number" },
        "recurringPattern": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "courseId", "type", "pricingModel", "feeAmount"]
    },
    "ClassSession": {
      "title": "Class Session",
      "description": "Occurrence of a class template",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "templateId": { "type": "string" },
        "tutorId": { "type": "string" },
        "studentIds": { "type": "array", "items": { "type": "string" } },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled", "no_show"] },
        "meetingLink": { "type": "string" },
        "roomNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "templateId", "startTime", "endTime"]
    },
    "Wallet": {
      "title": "Wallet",
      "description": "Student wallet for credits",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "studentId": { "type": "string" },
        "balanceCredits": { "type": "number" },
        "balanceCurrency": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "studentId", "balanceCredits"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Student enrollment in a class instance",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "studentId": { "type": "string" },
        "instanceId": { "type": "string" },
        "enrollmentDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "inactive", "completed"] }
      },
      "required": ["organizationId", "studentId", "instanceId", "enrollmentDate", "status"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Invoice for a student",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "studentId": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "periodStart": { "type": "string", "format": "date-time" },
        "periodEnd": { "type": "string", "format": "date-time" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "amount": { "type": "number" },
              "quantity": { "type": "number" }
            },
            "required": ["description", "amount", "quantity"]
          }
        },
        "subtotal": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "totalAmount": { "type": "number" },
        "amountPaid": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "partial", "paid", "overdue"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "pdfUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "studentId", "totalAmount", "status"]
    },
    "Document": {
      "title": "Document",
      "description": "Document shared with student",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "studentId": { "type": "string" },
        "uploadedByUserId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileType": { "type": "string" },
        "fileSize": { "type": "number" },
        "storagePath": { "type": "string" },
        "category": { "type": "string" },
        "videoId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deletedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "studentId", "uploadedByUserId", "fileName", "storagePath"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "Chat conversation",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "group"] },
        "createdByUserId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "type", "createdByUserId"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "conversationId": { "type": "string" },
        "senderUserId": { "type": "string" },
        "messageType": { "type": "string", "enum": ["text", "file", "system"] },
        "content": { "type": "string" },
        "metadata": { "type": "object" },
        "isEdited": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["conversationId", "senderUserId", "messageType", "content"]
    },
    "TutorAvailability": {
      "title": "TutorAvailability",
      "description": "Tutor availability slots for ONE_ON_ONE classes",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "tutorId": { "type": "string" },
        "dayOfWeek": { "type": "number", "description": "0-6 for Sunday-Saturday" },
        "startTime": { "type": "string", "description": "HH:mm format" },
        "endTime": { "type": "string", "description": "HH:mm format" },
        "isAvailable": { "type": "boolean" }
      },
      "required": ["organizationId", "tutorId", "dayOfWeek", "startTime", "endTime", "isAvailable"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Wallet transaction (top-up or deduction)",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "studentId": { "type": "string" },
        "type": { "type": "string", "enum": ["topup", "deduction"] },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "method": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "studentId", "type", "amount", "date"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "Student assessment or assignment",
      "type": "object",
      "properties": {
        "organizationId": { "type": "string" },
        "studentId": { "type": "string" },
        "tutorId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["quiz", "exam", "assignment"] },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "totalScore": { "type": "number" },
        "feedback": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "submitted", "graded"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["organizationId", "studentId", "title", "type", "date"]
    }
  },
  "firestore": {
    "/tutor_profiles/{userId}": {
      "schema": { "$ref": "#/entities/TutorProfile" },
      "description": "Tutor profiles"
    },
    "/parent_profiles/{userId}": {
      "schema": { "$ref": "#/entities/ParentProfile" },
      "description": "Parent profiles"
    },
    "/student_profiles/{userId}": {
      "schema": { "$ref": "#/entities/StudentProfile" },
      "description": "Student profiles"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Global user accounts"
    },
    "/organizations/{organizationId}": {
      "schema": { "$ref": "#/entities/Organization" },
      "description": "Organizations (tenants)"
    },
    "/organization_members/{memberId}": {
      "schema": { "$ref": "#/entities/OrganizationMember" },
      "description": "Members of organizations"
    },
    "/students/{studentId}": {
      "schema": { "$ref": "#/entities/Student" },
      "description": "Students"
    },
    "/student_parents/{studentParentId}": {
      "schema": { "$ref": "#/entities/StudentParent" },
      "description": "Links between students and parents"
    },
    "/programs/{programId}": {
      "schema": { "$ref": "#/entities/Program" },
      "description": "Educational programs"
    },
    "/courses/{courseId}": {
      "schema": { "$ref": "#/entities/Course" },
      "description": "Courses within programs"
    },
    "/class_templates/{templateId}": {
      "schema": { "$ref": "#/entities/ClassTemplate" },
      "description": "Definitions of class offerings and recurring rules"
    },
    "/class_sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ClassSession" },
      "description": "Occurrences of class templates"
    },
    "/wallets/{walletId}": {
      "schema": { "$ref": "#/entities/Wallet" },
      "description": "Student wallets"
    },
    "/enrollments/{enrollmentId}": {
      "schema": { "$ref": "#/entities/Enrollment" },
      "description": "Student enrollments in class instances"
    },
    "/invoices/{invoiceId}": {
      "schema": { "$ref": "#/entities/Invoice" },
      "description": "Invoices"
    },
    "/documents/{documentId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Documents"
    },
    "/conversations/{conversationId}": {
      "schema": { "$ref": "#/entities/Conversation" },
      "description": "Conversations"
    },
    "/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages"
    },
    "/tutor_availability/{availabilityId}": {
      "schema": { "$ref": "#/entities/TutorAvailability" },
      "description": "Tutor availability slots"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Wallet transactions"
    },
    "/assessments/{assessmentId}": {
      "schema": { "$ref": "#/entities/Assessment" },
      "description": "Student assessments and assignments"
    }
  }
}
